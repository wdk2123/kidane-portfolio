# Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# Django Backend API URL (no trailing slash)
# Development (direct to Django): http://127.0.0.1:8000/api
# Development (Vite proxy, avoids CORS): /api
# Production: https://your-api.onrender.com/api
# Omit entirely in production builds to use mock data only
VITE_API_URL=http://127.0.0.1:8000/api
